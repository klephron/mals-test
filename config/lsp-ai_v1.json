{
  "memory": {
    "file_store": {}
  },
  "models": {
    "model1": {
      "type": "open_ai",
      "chat_endpoint": "http://localhost:9652/v1/chat/completions",
      "model": "local-model",
      "auth_token": ""
    }
  },
  "completion": {
    "model": "model1",
    "parameters": {
      "max_context": 12000,
      "max_tokens": 256,
      "temperature": 0.2,
      "top_p": 0.95,
      "frequency_penalty": 0.0,
      "presence_penalty": 0.0,
      "messages": [
        {
          "role": "system",
          "content": "You are an expert code completion AI. Complete the code snippet accurately and concisely. Follow the existing code style and patterns. Only provide the completion without explanations."
        },
        {
          "role": "user",
          "content": "{CODE}"
        }
      ]
    }
  }
}
